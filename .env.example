# ===========================================
# AI Autonomous Research Agent - Configuration
# ===========================================
# Copy this file to .env and fill in your values

# --- API Keys ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- LLM Settings ---
MODEL_NAME=claude-3-haiku-20240307
TEMPERATURE=0.7

# --- RAG Settings ---
DATA_PATH=data
INDEX_PATH=faiss_index
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVER_K=4

# --- API Settings ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Memory Settings ---
MAX_MEMORY_TURNS=10
